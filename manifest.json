{
  "manifest_version": 3,
  "name": "Corretor Ortográfico para WhatsApp Web",
  "version": "1.0.0",
  "description": "Adiciona um botão de correção ortográfica via IA (OpenRouter) ao lado do microfone no WhatsApp Web.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://openrouter.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Corretor Ortográfico - Configurações"
  }
}
